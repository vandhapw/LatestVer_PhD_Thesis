# ─────────────────────────────────────────────────────────
# Ver13 environment configuration — copy to .env and fill in
# Never commit .env to source control (see .gitignore)
# ─────────────────────────────────────────────────────────

# Ollama Cloud API key (get from https://ollama.com)
OLLAMA_API_KEY=

# MongoDB connection string for the digital-twin sink
# Example (do NOT commit the real one):
# MONGODB_URI=mongodb://USER:PASSWORD@HOST:PORT/DB?authSource=admin
MONGODB_URI=

# MongoDB database & collection names
MONGO_DB=server_db
MONGO_COLLECTION=simulated_smart_manufactured_data

# Kafka brokers (comma-separated host:port pairs)
KAFKA_BROKERS=10.247.166.188:9092,10.247.166.188:29092
KAFKA_TOPIC=simulated_digitaltwin_manufactured

# Default LLM model on Ollama Cloud
OLLAMA_MODEL=glm-5.1:cloud
